{
    "name": "nyoncode/wire-boost",
    "description": "AI tooling for the Wire ecosystem – an MCP server, AI guidelines and agent skills for wire-core, wire-forms, wire-table and wire-sortable.",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Ondrej Nyklicek",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.2",
        "nyoncode/wire-core": "^1.0|@dev",
        "illuminate/support": "^11.0|^12.0|^13.0",
        "illuminate/console": "^11.0|^12.0|^13.0",
        "laravel/mcp": "^0.8",
        "livewire/livewire": "^3.0",
        "nyoncode/laravel-package-toolkit": "^2.0.1"
    },
    "require-dev": {
        "orchestra/testbench": "^9.0|^10.0|^11.0",
        "laravel/pint": "^1.29",
        "pestphp/pest": "^2.0|^3.0|^4.0"
    },
    "suggest": {
        "nyoncode/wire-forms": "Enables form introspection tools.",
        "nyoncode/wire-table": "Enables table introspection tools.",
        "nyoncode/wire-sortable": "Enables sortable guidelines and skills."
    },
    "autoload": {
        "psr-4": {
            "NyonCode\\WireBoost\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "NyonCode\\WireBoost\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "NyonCode\\WireBoost\\WireBoostServiceProvider"
            ]
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    }
}
